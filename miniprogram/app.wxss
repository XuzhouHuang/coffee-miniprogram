/* Global styles - Nordic magazine feel */
page {
  background-color: #FAF8F5;
  color: #2C2825;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Noto Serif SC', serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx 32rpx;
}

/* Cards */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* Typography */
.title-lg {
  font-size: 40rpx;
  font-weight: 700;
  color: #2C2825;
  letter-spacing: -0.5rpx;
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2825;
}

.title-sm {
  font-size: 28rpx;
  font-weight: 600;
  color: #6B6058;
}

.text-body {
  font-size: 28rpx;
  color: #6B6058;
}

.text-muted {
  font-size: 24rpx;
  color: #9C9490;
}

.text-hint {
  font-size: 22rpx;
  color: #B8B0A8;
}

/* Badges */
.badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.badge-warm {
  background: #EBE5DD;
  color: #8B7355;
}

.badge-outline {
  background: transparent;
  border: 1rpx solid #E8E2DA;
  color: #9C9490;
}

/* Source colors for news */
.source-daily-coffee-news { background: #E8D5C4; color: #8B5E3C; }
.source-perfect-daily-grind { background: #D4E8D4; color: #3C6B3C; }
.source-sprudge { background: #D4D8E8; color: #3C4A6B; }
.source-coffee-review { background: #E8E4D4; color: #6B5E3C; }
.source-fresh-cup { background: #E4D4E8; color: #6B3C6B; }
.source-barista-hustle { background: #D4E4E8; color: #3C5E6B; }

/* Divider */
.divider {
  height: 1rpx;
  background: linear-gradient(to right, transparent, rgba(200,168,130,0.15), transparent);
  margin: 24rpx 0;
}

/* Loading */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  color: #B8B0A8;
  font-size: 26rpx;
}

/* Empty state */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #B8B0A8;
  font-size: 28rpx;
}
