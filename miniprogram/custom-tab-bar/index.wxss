.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #FAF8F5;
  border-top: 1rpx solid #E8E2DA;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #9C9490;
}

.tab-item.active .tab-text {
  color: #8B7355;
  font-weight: 600;
}
