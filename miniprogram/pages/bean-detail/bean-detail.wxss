.detail-header {
  display: flex;
  align-items: center;
  padding: 32rpx 0 16rpx;
  flex-wrap: wrap;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  padding: 10rpx 0;
}

.info-label {
  color: #B8B0A8;
  font-size: 26rpx;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  color: #2C2825;
  font-size: 26rpx;
  flex: 1;
}

.flavor-text {
  display: block;
  font-size: 28rpx;
  color: #6B6058;
  font-style: italic;
  margin-top: 12rpx;
  line-height: 1.6;
}

.notes-text {
  display: block;
  font-size: 26rpx;
  color: #9C9490;
  margin-top: 12rpx;
  line-height: 1.8;
  white-space: pre-line;
}

.purchase-list {
  margin-top: 16rpx;
}

.purchase-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0ECE6;
}

.purchase-item:last-child {
  border-bottom: none;
}

.purchase-main {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.purchase-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #8B7355;
}
