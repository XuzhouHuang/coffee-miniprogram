<view class="home-container">
  <!-- Hero -->
  <view class="hero">
    <text class="hero-icon">☕</text>
    <text class="hero-title">COFFEE JOURNAL</text>
    <text class="hero-sub">面包 · 咖啡 · 好天气</text>
  </view>

  <!-- Quick entry -->
  <view class="entry-grid">
    <view class="entry-card" bindtap="goToBeans">
      <text class="entry-icon">🫘</text>
      <text class="entry-label">咖啡豆</text>
      <text class="entry-sub">My Beans</text>
    </view>
    <view class="entry-card" bindtap="goToKnowledge">
      <text class="entry-icon">📖</text>
      <text class="entry-label">知识库</text>
      <text class="entry-sub">Knowledge</text>
    </view>
    <view class="entry-card" bindtap="goToPurchases">
      <text class="entry-icon">💰</text>
      <text class="entry-label">消费</text>
      <text class="entry-sub">Spending</text>
    </view>
  </view>

  <!-- Loading -->
  <view class="loading" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- Today's News -->
  <view class="section" wx:if="{{!loading && todayNews.length > 0}}">
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">☕ 今日咖啡</text>
        <text class="section-date">{{today}}</text>
      </view>
      <view class="news-list">
        <view class="news-item" wx:for="{{todayNews}}" wx:key="id" bindtap="onNewsClick" data-item="{{item}}">
          <text class="news-source {{item.sourceClass || ''}}">{{item.source}}</text>
          <text class="news-title">{{item.titleZh || item.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Yesterday's News -->
  <view class="section" wx:if="{{!loading && yesterdayNews.length > 0}}">
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">📰 昨日咖啡</text>
        <text class="section-date">{{yesterday}}</text>
      </view>
      <view class="news-list">
        <view class="news-item" wx:for="{{yesterdayNews}}" wx:key="id" bindtap="onNewsClick" data-item="{{item}}">
          <text class="news-source {{item.sourceClass || ''}}">{{item.source}}</text>
          <text class="news-title">{{item.titleZh || item.title}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Empty -->
  <view class="empty" wx:if="{{!loading && todayNews.length === 0 && yesterdayNews.length === 0}}">
    <text>暂无新闻</text>
  </view>
</view>
