/* Global styles - Minimal, clean, thin line dividers, blue accent */
page {
  background-color: #F7F6F3;
  color: #2C2C2C;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro Text', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  padding: 24rpx 36rpx;
  padding-bottom: 130rpx;
}

/* Typography */
.title-lg {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.title-md {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.title-sm {
  font-size: 26rpx;
  font-weight: 500;
  color: #666666;
}

.text-body {
  font-size: 28rpx;
  color: #333333;
}

.text-muted {
  font-size: 24rpx;
  color: #999999;
}

.text-hint {
  font-size: 22rpx;
  color: #BBBBBB;
}

/* Blue accent */
.text-accent {
  color: #7B8FA3;
}

/* Badges - minimal */
.badge {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.badge-default {
  background: #F5F5F5;
  color: #666666;
}

.badge-accent {
  background: #EEF1F5;
  color: #7B8FA3;
}

.badge-outline {
  background: transparent;
  border: 1rpx solid #E5E5E5;
  color: #999999;
}

/* Thin line divider */
.divider {
  height: 1rpx;
  background: #EEEEEE;
  margin: 24rpx 0;
}

/* Source colors for news - subtle */
.source-daily-coffee-news { background: #FFF8F2; color: #C4875C; }
.source-perfect-daily-grind { background: #F2F8F2; color: #5C8B5C; }
.source-sprudge { background: #F2F4F8; color: #5C6B8B; }
.source-coffee-review { background: #F8F6F2; color: #8B7D5C; }
.source-fresh-cup { background: #F6F2F8; color: #7D5C8B; }
.source-barista-hustle { background: #F2F6F8; color: #5C7D8B; }

/* Loading */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  color: #BBBBBB;
  font-size: 26rpx;
}

/* Empty */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #CCCCCC;
  font-size: 26rpx;
}
