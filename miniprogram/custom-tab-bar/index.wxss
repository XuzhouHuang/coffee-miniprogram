.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: #F5F0EA;
  border-top: 1rpx solid #E8E0D4;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  opacity: 0.4;
  transition: opacity 0.2s;
}

.tab-item.active {
  opacity: 1;
}

.tab-icon {
  width: 52rpx;
  height: 52rpx;
  position: relative;
}

.icon-svg {
  width: 100%;
  height: 100%;
}

.line-icon {
  width: 100%;
  height: 100%;
  position: relative;
}

/* ---- News (newspaper) icon ---- */
.news-icon .news-paper {
  position: absolute;
  top: 4rpx;
  left: 6rpx;
  width: 40rpx;
  height: 44rpx;
  border: 2.5rpx solid #5C4A3A;
  border-radius: 4rpx;
}
.news-icon .news-line {
  position: absolute;
  left: 14rpx;
  height: 2.5rpx;
  background: #5C4A3A;
  border-radius: 2rpx;
}
.news-icon .l1 { top: 16rpx; width: 24rpx; }
.news-icon .l2 { top: 24rpx; width: 20rpx; }
.news-icon .l3 { top: 32rpx; width: 24rpx; }

/* ---- Coffee cup icon ---- */
.cup-icon .cup-body {
  position: absolute;
  bottom: 4rpx;
  left: 8rpx;
  width: 28rpx;
  height: 30rpx;
  border: 2.5rpx solid #5C4A3A;
  border-radius: 0 0 8rpx 8rpx;
  border-top: none;
}
.cup-icon .cup-body::before {
  content: '';
  position: absolute;
  top: -2.5rpx;
  left: -2.5rpx;
  width: 28rpx;
  height: 2.5rpx;
  background: #5C4A3A;
  border-radius: 2rpx;
}
.cup-icon .cup-handle {
  position: absolute;
  bottom: 12rpx;
  right: 6rpx;
  width: 10rpx;
  height: 16rpx;
  border: 2.5rpx solid #5C4A3A;
  border-left: none;
  border-radius: 0 6rpx 6rpx 0;
}
.cup-icon .cup-steam {
  position: absolute;
  width: 2.5rpx;
  height: 10rpx;
  background: #5C4A3A;
  border-radius: 2rpx;
  opacity: 0.6;
}
.cup-icon .s1 { left: 16rpx; top: 2rpx; transform: rotate(-8deg); }
.cup-icon .s2 { left: 26rpx; top: 0rpx; transform: rotate(8deg); }

/* ---- Book icon ---- */
.book-icon .book-cover {
  position: absolute;
  top: 6rpx;
  left: 8rpx;
  width: 34rpx;
  height: 40rpx;
  border: 2.5rpx solid #5C4A3A;
  border-radius: 2rpx 6rpx 6rpx 2rpx;
}
.book-icon .book-spine {
  position: absolute;
  top: 6rpx;
  left: 8rpx;
  width: 2.5rpx;
  height: 40rpx;
  background: #5C4A3A;
}
.book-icon .book-page {
  position: absolute;
  top: 16rpx;
  left: 18rpx;
  width: 16rpx;
  height: 2.5rpx;
  background: #5C4A3A;
  border-radius: 2rpx;
}

/* ---- Wallet icon ---- */
.wallet-icon .wallet-body {
  position: absolute;
  top: 10rpx;
  left: 6rpx;
  width: 38rpx;
  height: 28rpx;
  border: 2.5rpx solid #5C4A3A;
  border-radius: 6rpx;
}
.wallet-icon .wallet-flap {
  position: absolute;
  top: 6rpx;
  left: 10rpx;
  width: 30rpx;
  height: 8rpx;
  border: 2.5rpx solid #5C4A3A;
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
}
.wallet-icon .wallet-coin {
  position: absolute;
  top: 20rpx;
  right: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border: 2.5rpx solid #5C4A3A;
  border-radius: 50%;
}
