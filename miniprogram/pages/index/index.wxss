.home {
  padding: 0 36rpx;
  padding-bottom: 130rpx;
  background: #F5F5F0;
}

/* Header */
.header {
  padding: 48rpx 0 24rpx;
}

.header-top {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.brand-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A1A;
  letter-spacing: 2rpx;
}

.brand-dot {
  color: #CCCCCC;
  font-size: 28rpx;
}

.brand-sub {
  font-size: 22rpx;
  color: #BBBBBB;
  letter-spacing: 1rpx;
}

/* Thin line separator */
.thin-line {
  height: 1rpx;
  background: #EBEBEB;
  margin: 0;
}

/* Nav row */
.nav-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}

.nav-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.nav-icon {
  font-size: 32rpx;
}

.nav-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.nav-sep {
  width: 1rpx;
  height: 32rpx;
  background: #EEEEEE;
}

/* News section */
.news-section {
  padding: 28rpx 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #3EB4E8;
  letter-spacing: 3rpx;
}

.section-date {
  font-size: 22rpx;
  color: #CCCCCC;
}

/* News list */
.news-list {
  display: flex;
  flex-direction: column;
}

.news-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F0;
}

.news-item:last-child {
  border-bottom: none;
}

.news-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3EB4E8;
  flex-shrink: 0;
  margin-top: 16rpx;
}

.news-content {
  flex: 1;
  min-width: 0;
}

.news-source-text {
  display: block;
  font-size: 20rpx;
  color: #BBBBBB;
  margin-bottom: 4rpx;
}

.news-title {
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Loading & empty */
.loading {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  color: #CCCCCC;
  font-size: 26rpx;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #CCCCCC;
}
