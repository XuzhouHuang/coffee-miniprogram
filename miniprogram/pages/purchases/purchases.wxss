.page-title {
  padding: 32rpx 0 16rpx;
}

.tab-switcher {
  display: flex;
  white-space: nowrap;
  margin-bottom: 24rpx;
  padding: 4rpx 0;
}

.tab-btn {
  display: inline-block;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  margin-right: 12rpx;
  border-radius: 12rpx;
  color: #999999;
  background: transparent;
  border: 1rpx solid #EBEBEB;
  transition: all 0.2s;
}

.tab-active {
  color: #3EB4E8;
  background: transparent;
  border-color: #3EB4E8;
  font-weight: 600;
}

.purchase-card {
  padding: 24rpx 28rpx;
}

.purchase-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.purchase-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #2C2825;
}

.purchase-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #3EB4E8;
  flex-shrink: 0;
}

.purchase-meta {
  display: flex;
  gap: 0;
  margin-top: 8rpx;
}
